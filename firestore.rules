rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /registrations/{document} {
      // READ / UPDATE / DELETE: admin only (the account you create in Firebase Auth).
      allow read, update, delete: if request.auth != null;

      // CREATE: denied for all clients. Registrations are created and completed
      // exclusively by the Cloud Functions backend via the Admin SDK, which
      // bypasses these rules. This is what makes payment status trustworthy —
      // no browser can insert a "paid" record. Payment truth comes from the
      // Bachs webhook, verified server-side.
      allow create: if false;
    }

    // Webhook idempotency ledger — server-only (Admin SDK bypasses rules).
    match /webhookEvents/{document} {
      allow read, write: if false;
    }

    // Everything else is denied by default.
  }
}
